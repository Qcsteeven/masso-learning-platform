# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=change_me

# Neo4j
NEO4J_PASSWORD=change_me

# Redis
REDIS_PASSWORD=change_me

# Grafana
GRAFANA_PASSWORD=change_me

# Backend — JWT
JWT_SECRET=change_me_32_chars_minimum

# Backend — LLM providers (leave blank to use template-only fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Backend — database URLs (used by the backend service, not compose)
DATABASE_URL=postgresql+asyncpg://masso:change_me@postgres:5432/masso
REDIS_URL=redis://:change_me@redis:6379/0
